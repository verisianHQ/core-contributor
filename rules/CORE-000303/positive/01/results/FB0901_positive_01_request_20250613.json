        "Check": {
            "all": [
                {
                    "name": "--TEST",
                    "operator": "is_not_unique_relationship",
                    "value": "--TESTCD"
                }
            ]
        },
        "Core": {
            "Id": "CORE-000303",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "--TESTCD and --TEST should have a one-to-one relationship",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "--TESTCD and --TEST do not have a one-to-one relationship",
            "Output_Variables": [
                "--TESTCD",
                "--TEST"
            ]
        },
        "Scope": {
