{
    "rule": {
        "Authorities": [
            {
                "Organization": "FDA",
                "Standards": [
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "FDA",
                                        "Section": "FDAB026",
                                        "Cited_Guidance": "Records with a baseline flag should have a corresponding standard result with a standardized unit where available."
                                    }
                                ],
                                "Origin": "FDA Business Rules",
                                "Version": "1.5",
                                "Rule_Identifier": {
                                    "Id": "FB2604",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.3"
                    },
                    {
                        "Name": "SDTMIG",
                        "References": [
                            {
                                "Citations": [
                                    {
                                        "Document": "FDA",
                                        "Section": "FDAB026",
                                        "Cited_Guidance": "Records with a baseline flag should have a corresponding standard result with a standardized unit where available."
                                    }
                                ],
                                "Origin": "FDA Business Rules",
                                "Version": "1.5",
                                "Rule_Identifier": {
                                    "Id": "FB2604",
                                    "Version": "1"
                                }
                            }
                        ],
                        "Version": "3.4"
                    }
                ]
            }
        ],
        "Check": {
            "all": [
                {
                    "name": "--STRESC",
                    "operator": "non_empty"
                },
                {
                    "name": "--LOBXFL",
                    "operator": "equal_to",
                    "value": "Y",
                    "value_is_literal": true
                },
                {
                    "name": "--LOBXFL",
                    "operator": "is_not_unique_set",
                    "value": [
                        "--TESTCD",
                        "--CAT",
                        "--SCAT",
                        "--SPEC",
                        "--METHOD",
                        "USUBJID"
                    ]
                }
            ]
        },
        "Core": {
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "There should be only one record with a last observation before exposure flag and non missing character standard result value having the same --TESTCD, --CAT, --SCAT, --SPEC, --METHOD values.",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "There are multiple records per assigned last observation before exposure flag (--LOBXFL).",
            "Output_Variables": [
                "--TESTCD",
                "--CAT",
                "--SCAT",
                "--SPEC",
                "--METHOD",
                "--LOBXFL"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "FINDINGS"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
