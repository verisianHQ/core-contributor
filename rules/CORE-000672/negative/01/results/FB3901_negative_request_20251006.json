        "Check": {
            "all": [
                {
                    "name": "--STNRHI",
                    "operator": "non_empty"
                },
                {
                    "name": "--STNRLO",
                    "operator": "non_empty"
                },
                {
                    "name": "--STNRHI",
                    "operator": "less_than_or_equal_to",
                    "value": "--STNRLO"
                }
            ]
        },
        "Core": {
            "Id": "CORE-000672",
            "Status": "Published",
            "Version": "1"
        },
        "Description": "--STNRHI should be greater than --STNRLO when both values are completed.",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "The upper limit of the reference range (--STNRHI) is lower than or equal to the lower limit of the reference range (--STNRLO).",
            "Output_Variables": [
                "--TESTCD",
                "--STNRLO",
                "--STNRHI"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "FINDINGS"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
