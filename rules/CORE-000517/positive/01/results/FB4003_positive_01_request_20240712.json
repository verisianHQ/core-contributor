        "Check": {
            "all": [
                {
                    "name": "--DOSTOT",
                    "operator": "non_empty"
                },
                {
                    "name": "--DOSTOT",
                    "operator": "less_than",
                    "value": 0
                }
            ]
        },
        "Core": {
            "Id": "",
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Value for Total Daily Dose (--DOSTOT) should not be negative",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "--DOSTOT is lower than zero"
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "INTERVENTIONS"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
