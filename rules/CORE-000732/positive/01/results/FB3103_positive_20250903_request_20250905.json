        "Check": {
            "all": [
                {
                    "name": "--STRESC",
                    "operator": "non_empty"
                },
                {
                    "name": "--STRESC",
                    "operator": "not_matches_regex",
                    "value": "^-?(0|[1-9]\\d*)(\\.\\d+)?$"
                },
                {
                    "name": "--STRESN",
                    "operator": "non_empty"
                }
            ]
        },
        "Core": {
            "Id": "CORE-000732",
            "Status": "Published",
            "Version": "1"
        },
        "Description": "--STRESC is not populated with a numeric value, but --STRESN is not empty.",
        "Executability": "Fully Executable",
        "Outcome": {
            "Message": "--STRESC is not numeric but --STRESN is not empty",
            "Output_Variables": [
                "--STRESC",
                "--STRESN"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "FINDINGS"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
