        "Check": {
            "all": [
                {
                    "name": "variable_data_type",
                    "operator": "equal_to",
                    "value": "Char"
                },
                {
                    "name": "variable_value",
                    "operator": "non_empty"
                },
                {
                    "name": "variable_value",
                    "operator": "equal_to",
                    "value": ".",
                    "value_is_literal": true
                }
            ]
        },
        "Core": {
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "Text variables in submitted datasets should not contain '.' as an entire value.",
        "Executability": "Fully Executable",
        "Outcome": {
