        "Check": {
            "all": [
                {
                    "name": "--ORNRLO",
                    "operator": "non_empty"
                },
                {
                    "name": "--ORNRLO",
                    "operator": "matches_regex",
                    "value": "^-?(0|[1-9]\\d*)(\\.\\d+)?$"
                },
                {
                    "name": "--ORNRHI",
                    "operator": "non_empty"
                },
                {
                    "name": "--ORNRHI",
                    "operator": "matches_regex",
                    "value": "^-?(0|[1-9]\\d*)(\\.\\d+)?$"
                },
                {
                    "name": "--ORNRHI",
                    "operator": "less_than_or_equal_to",
                    "value": "--ORNRLO"
                }
            ]
        },
        "Core": {
            "Status": "Draft",
            "Version": "1"
        },
        "Description": "--ORNRHI should be higher than --ORNRLO when both values are completed.",
        "Executability": "Partially Executable - Possible Underreporting",
        "Outcome": {
            "Message": "The upper limit of the reference range (--ORNRHI) is lower than or equal to the lower limit of the reference range (--ORNRLO).",
            "Output_Variables": [
                "--TESTCD",
                "--ORNRHI",
                "--ORNRLO"
            ]
        },
        "Scope": {
            "Classes": {
                "Include": [
                    "FINDINGS"
                ]
            },
            "Domains": {
                "Include": [
                    "ALL"
                ]
            }
        },
        "Sensitivity": "Record",
        "Rule_Type": "Record Data"
    },
